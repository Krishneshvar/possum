<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.possum.ui.people.UserFormController"
            fitToWidth="true"
            stylesheets="@../../styles/inventory.css"
            styleClass="workspace-view">

    <VBox spacing="20" alignment="TOP_LEFT">
        <HBox styleClass="view-header">
            <Label fx:id="titleLabel" text="Add Employee" styleClass="view-title"/>
        </HBox>

        <VBox spacing="20" maxWidth="600">
            <VBox styleClass="card" spacing="15">
                <Label text="Employee Profile" styleClass="card-title"/>
                <Label text="Basic identifying information for this employee." styleClass="helper-text" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                <Separator style="-fx-padding: 0 0 10 0;" />

                <HBox spacing="20">
                    <VBox styleClass="form-group" HBox.hgrow="ALWAYS">
                        <Label text="Full Name *" styleClass="form-label"/>
                        <TextField fx:id="nameField" promptText="e.g., John Smith" styleClass="text-field" accessibleText="Employee Full Name"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox styleClass="card" spacing="15">
                <Label text="System Access" styleClass="card-title"/>
                <Label text="Authentication credentials and account status." styleClass="helper-text" style="-fx-text-fill: #64748b; -fx-font-size: 12px;"/>
                <Separator style="-fx-padding: 0 0 10 0;" />

                <HBox spacing="20">
                    <VBox styleClass="form-group" HBox.hgrow="ALWAYS">
                        <Label text="Username *" styleClass="form-label"/>
                        <TextField fx:id="usernameField" promptText="e.g., jsmith" styleClass="text-field" accessibleText="System Username"/>
                    </VBox>
                    <VBox styleClass="form-group" HBox.hgrow="ALWAYS">
                        <Label text="Status *" styleClass="form-label"/>
                        <ComboBox fx:id="statusCombo" maxWidth="Infinity" styleClass="combo-box" accessibleText="Account Status"/>
                    </VBox>
                </HBox>
                <VBox styleClass="form-group">
                    <Label text="Password" styleClass="form-label"/>
                    <PasswordField fx:id="passwordField" promptText="Enter password" styleClass="text-field" accessibleText="Account Password"/>
                    <Label fx:id="passwordHelper" text="Required for new employees. Leave blank to keep current password if editing." styleClass="helper-text" style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>
                </VBox>
            </VBox>

            <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                <Button text="Cancel" onAction="#handleCancel" styleClass="action-button" cancelButton="true" accessibleText="Cancel and close"/>
                <Button fx:id="saveButton" text="Save Employee" onAction="#handleSave" styleClass="action-button, primary-button" defaultButton="true" accessibleText="Save employee details"/>
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>
