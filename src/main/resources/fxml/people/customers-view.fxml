<?xml version="1.0" encoding="UTF-8"?>

<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.control.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import com.possum.ui.common.controls.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.people.CustomersController"
      styleClass="workspace-view"
      stylesheets="@../../styles/inventory.css">

    <!-- Header -->
    <HBox styleClass="view-header" alignment="CENTER_LEFT">
        <VBox>
            <Label text="Customers" styleClass="view-title"/>
            <Label text="Manage your customer base" styleClass="view-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button text="Refresh" onAction="#handleRefresh" styleClass="action-button">
                <graphic><FontIcon iconLiteral="bx-sync" iconSize="16"/></graphic>
                <tooltip>
                    <Tooltip text="Reload customer list"/>
                </tooltip>
            </Button>
            <Button fx:id="importButton" text="Import CSV" onAction="#handleImport" styleClass="action-button" accessibleText="Import customers from CSV file">
                <graphic><FontIcon iconLiteral="bx-upload" iconSize="16"/></graphic>
                <tooltip>
                    <Tooltip text="Import customers from a CSV file (name, phone, email, address)"/>
                </tooltip>
            </Button>
            <Button fx:id="addButton" text="Add Customer" onAction="#handleAdd" styleClass="action-button, primary-button" accessibleText="Add a new customer">
                <graphic><FontIcon iconLiteral="bx-plus" iconSize="16" iconColor="white"/></graphic>
                <tooltip>
                    <Tooltip text="Create a new customer record"/>
                </tooltip>
            </Button>
        </HBox>
    </HBox>

    <!-- Main Content -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <FilterBar fx:id="filterBar"/>

        <DataTableView fx:id="dataTable" VBox.vgrow="ALWAYS" styleClass="data-table">
            <emptyMessage>No customers found. Click + Add Customer to add a new customer.</emptyMessage>
        </DataTableView>

        <PaginationBar fx:id="paginationBar"/>
    </VBox>

</VBox>
