<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.reports.ReportsController"
      spacing="20"
      alignment="TOP_LEFT">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="Reports" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Date Range:"/>
        <ComboBox fx:id="dateRangeCombo" onAction="#handleDateRangeChange"/>
        <Button text="Refresh" onAction="#handleRefresh"/>
    </HBox>
    
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox spacing="20">
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8;">
                <Label text="Sales Summary" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <GridPane hgap="20" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="25"/>
                    </columnConstraints>
                    <VBox GridPane.columnIndex="0">
                        <Label text="Total Sales" style="-fx-text-fill: #666;"/>
                        <Label fx:id="totalSalesLabel" text="$0.00" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox GridPane.columnIndex="1">
                        <Label text="Transactions" style="-fx-text-fill: #666;"/>
                        <Label fx:id="transactionsLabel" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox GridPane.columnIndex="2">
                        <Label text="Average Sale" style="-fx-text-fill: #666;"/>
                        <Label fx:id="avgSaleLabel" text="$0.00" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox GridPane.columnIndex="3">
                        <Label text="Total Tax" style="-fx-text-fill: #666;"/>
                        <Label fx:id="totalTaxLabel" text="$0.00" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                    </VBox>
                </GridPane>
            </VBox>
            
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8;">
                <Label text="Top Selling Products" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <BarChart fx:id="topProductsChart" prefHeight="300">
                    <xAxis>
                        <CategoryAxis side="BOTTOM"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis side="LEFT"/>
                    </yAxis>
                </BarChart>
            </VBox>
            
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8;">
                <Label text="Sales Trend" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <LineChart fx:id="salesTrendChart" prefHeight="300">
                    <xAxis>
                        <CategoryAxis side="BOTTOM"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis side="LEFT"/>
                    </yAxis>
                </LineChart>
            </VBox>
            
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8;">
                <Label text="Inventory Movement" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <TableView fx:id="inventoryTable" prefHeight="200"/>
            </VBox>
        </VBox>
    </ScrollPane>

</VBox>
