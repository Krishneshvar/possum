<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.reports.SalesReportsController"
      spacing="0"
      style="-fx-background-color: #f8fafc;">
    
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox>
            <Label text="Sales Reports" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #0f172a;"/>
            <Label text="Detailed period-wise sales breakdowns" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        
        <VBox spacing="2">
            <Label text="Period Type:" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
            <ComboBox fx:id="reportTypeCombo" onAction="#handleReportTypeChange"/>
        </VBox>
        
        <VBox spacing="2">
            <Label text="From Date:" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
            <DatePicker fx:id="startDatePicker" onAction="#handleDateChange"/>
        </VBox>
        
        <VBox spacing="2">
            <Label text="To Date:" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
            <DatePicker fx:id="endDatePicker" onAction="#handleDateChange"/>
        </VBox>

        <Separator orientation="VERTICAL" style="-fx-padding: 0 5;"/>

        <VBox spacing="2">
            <Label text="Filter Column:" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
            <ComboBox fx:id="amountFilterColCombo" prefWidth="120"/>
        </VBox>

        <VBox spacing="2">
            <Label text="Min Amount:" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
            <TextField fx:id="minAmountField" prefWidth="80" promptText="0.00"/>
        </VBox>

        <VBox spacing="2">
            <Label text="Max Amount:" style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
            <TextField fx:id="maxAmountField" prefWidth="80" promptText="Max"/>
        </VBox>
        
        <Button text="🧹 Reset" onAction="#handleReset" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-padding: 8 16; -fx-font-weight: 600; -fx-cursor: hand;">
            <HBox.margin>
                <Insets top="13"/>
            </HBox.margin>
        </Button>

        <Button text="🔄 Refresh" onAction="#handleRefresh" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-padding: 8 16; -fx-font-weight: 600; -fx-cursor: hand;">
            <HBox.margin>
                <Insets top="13"/>
            </HBox.margin>
        </Button>
    </HBox>
    
    <Separator style="-fx-padding: 20 0;"/>
    
    <VBox spacing="0" VBox.vgrow="ALWAYS" styleClass="pos-card">
        <TableView fx:id="breakdownTable" VBox.vgrow="ALWAYS" styleClass="pos-table">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="periodCol" text="Date" prefWidth="150"/>
                <TableColumn fx:id="transactionsCol" text="Transactions" prefWidth="100" style="-fx-alignment: CENTER;"/>
                <TableColumn fx:id="cashCol" text="Cash" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
                <TableColumn fx:id="upiCol" text="UPI" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
                <TableColumn fx:id="debitCardCol" text="Debit Card" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
                <TableColumn fx:id="creditCardCol" text="Credit Card" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
                <TableColumn fx:id="giftCardCol" text="Gift Card" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
                <TableColumn fx:id="salesCol" text="Gross Sales" prefWidth="120" style="-fx-alignment: CENTER-RIGHT;"/>
                <TableColumn fx:id="taxCol" text="Total Tax" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
                <TableColumn fx:id="discountCol" text="Discounts" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
                <TableColumn fx:id="refundsCol" text="Refunds" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
                <TableColumn fx:id="netSalesCol" text="Net Sales" prefWidth="120" style="-fx-alignment: CENTER-RIGHT;"/>
            </columns>
            <placeholder>
                <VBox alignment="CENTER" spacing="10">
                    <Label text="No records found for selected period" style="-fx-font-size: 14px; -fx-text-fill: #64748b;"/>
                </VBox>
            </placeholder>
        </TableView>

        <!-- Totals Bar -->
        <HBox fx:id="totalsBar" spacing="0" alignment="CENTER_LEFT" style="-fx-background-color: #f1f5f9; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0; -fx-padding: 12 0;">
            <Label fx:id="totalLabel" text="TOTALS" style="-fx-font-weight: 800; -fx-font-size: 11px; -fx-text-fill: #475569; -fx-padding: 0 0 0 10;"/>
            <Label fx:id="totalTransactionsLabel" text="0" style="-fx-font-weight: 800; -fx-text-fill: #1e293b;"/>
            <Label fx:id="totalCashLabel" text="₹0.00" style="-fx-font-weight: 700; -fx-text-fill: #1e293b; -fx-padding: 0 5 0 0;"/>
            <Label fx:id="totalUpiLabel" text="₹0.00" style="-fx-font-weight: 700; -fx-text-fill: #1e293b; -fx-padding: 0 5 0 0;"/>
            <Label fx:id="totalDebitLabel" text="₹0.00" style="-fx-font-weight: 700; -fx-text-fill: #1e293b; -fx-padding: 0 5 0 0;"/>
            <Label fx:id="totalCreditLabel" text="₹0.00" style="-fx-font-weight: 700; -fx-text-fill: #1e293b; -fx-padding: 0 5 0 0;"/>
            <Label fx:id="totalGiftLabel" text="₹0.00" style="-fx-font-weight: 700; -fx-text-fill: #1e293b; -fx-padding: 0 5 0 0;"/>
            <Label fx:id="totalSalesLabel" text="₹0.00" style="-fx-font-weight: 800; -fx-text-fill: #0f172a; -fx-padding: 0 5 0 0;"/>
            <Label fx:id="totalTaxLabel" text="₹0.00" style="-fx-font-weight: 700; -fx-text-fill: #1e293b; -fx-padding: 0 5 0 0;"/>
            <Label fx:id="totalDiscountLabel" text="₹0.00" style="-fx-font-weight: 700; -fx-text-fill: #1e293b; -fx-padding: 0 5 0 0;"/>
            <Label fx:id="totalRefundsLabel" text="₹0.00" style="-fx-font-weight: 700; -fx-text-fill: #1e293b; -fx-padding: 0 5 0 0;"/>
            <Label fx:id="totalNetSalesLabel" text="₹0.00" style="-fx-font-weight: 900; -fx-text-fill: #0891b2; -fx-font-size: 14px; -fx-padding: 0 10 0 0;"/>
        </HBox>
    </VBox>

</VBox>
