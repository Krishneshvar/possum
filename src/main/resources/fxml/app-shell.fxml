<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.possum.ui.AppShellController"
            stylesheets="@../styles/app-shell.css"
            styleClass="app-shell">

    <!-- Left: Sidebar Navigation -->
    <left>
        <VBox fx:id="sidebar" styleClass="sidebar" prefWidth="250" minWidth="250" maxWidth="250">
            <!-- Sidebar Header -->
            <HBox styleClass="sidebar-header" alignment="CENTER_LEFT" spacing="10">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>
                <Label text="POSSUM" styleClass="app-title"/>
            </HBox>

            <Separator/>

            <!-- Main Navigation -->
            <ScrollPane fx:id="navScrollPane" styleClass="nav-scroll" fitToWidth="true" VBox.vgrow="ALWAYS">
                <VBox fx:id="navMain" styleClass="nav-main" spacing="2">
                    <padding>
                        <Insets top="10" right="5" bottom="10" left="5"/>
                    </padding>
                </VBox>
            </ScrollPane>

            <Separator/>

            <!-- Secondary Navigation -->
            <VBox fx:id="navSecondary" styleClass="nav-secondary" spacing="2">
                <padding>
                    <Insets top="10" right="5" bottom="10" left="5"/>
                </padding>
            </VBox>

            <Separator/>

            <!-- User Section -->
            <HBox fx:id="navUser" styleClass="nav-user" alignment="CENTER_LEFT" spacing="10">
                <padding>
                    <Insets top="15" right="15" bottom="15" left="15"/>
                </padding>
                <Label fx:id="userNameLabel" text="Admin User" styleClass="user-name"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="logoutButton" text="Logout" styleClass="logout-btn" onAction="#handleLogout"/>
            </HBox>
        </VBox>
    </left>

    <!-- Top: Header Bar -->
    <top>
        <HBox fx:id="header" styleClass="header" alignment="CENTER_LEFT" spacing="15">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>
            <Label fx:id="pageTitleLabel" text="Dashboard" styleClass="page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="themeToggleButton" text="🌙" styleClass="icon-btn" onAction="#handleThemeToggle"/>
        </HBox>
    </top>

    <!-- Center: Dynamic Content Container -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
        </StackPane>
    </center>

</BorderPane>
