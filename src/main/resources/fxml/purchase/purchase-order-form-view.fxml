<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.possum.ui.purchase.PurchaseOrderFormController"
            fitToWidth="true"
            stylesheets="@../../styles/inventory.css"
            styleClass="workspace-view">

    <VBox spacing="20" alignment="TOP_LEFT">
        <!-- Header -->
        <HBox styleClass="view-header">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label fx:id="titleLabel" text="Purchase Order Form" styleClass="view-title"/>
                <Label text="Order new stock from suppliers" styleClass="view-subtitle"/>
            </VBox>
        </HBox>

        <!-- Supplier & Payment Section -->
        <HBox spacing="20">
            <!-- Supplier Section -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="card">
                <Label text="Supplier Information" styleClass="card-title"/>
                <Label text="Select the supplier for this purchase order" styleClass="view-subtitle" style="-fx-font-size: 12px;"/>
                <VBox styleClass="form-group">
                    <Label text="Supplier:" styleClass="form-label" labelFor="$supplierCombo"/>
                    <ComboBox fx:id="supplierCombo" promptText="Choose a supplier" maxWidth="Infinity" styleClass="combo-box"
                              accessibleText="Select a supplier for the purchase order"/>
                </VBox>
            </VBox>

            <!-- Payment Method Section -->
            <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="card">
                <Label text="Payment Information" styleClass="card-title"/>
                <Label text="Select the payment method" styleClass="view-subtitle" style="-fx-font-size: 12px;"/>
                <VBox styleClass="form-group">
                    <Label text="Payment Method:" styleClass="form-label" labelFor="$paymentMethodCombo"/>
                    <ComboBox fx:id="paymentMethodCombo" promptText="Choose payment method" maxWidth="Infinity" styleClass="combo-box"
                              accessibleText="Select the payment method"/>
                </VBox>
            </VBox>
        </HBox>
        
        <!-- Items Section -->
        <VBox spacing="15" VBox.vgrow="ALWAYS" styleClass="card">
            <Label text="Order Items" styleClass="card-title"/>
            <Label text="Add products to this purchase order" styleClass="view-subtitle" style="-fx-font-size: 12px;"/>

            <!-- Search Bar -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchVariantField" 
                          promptText="Search by product name or SKU and press Enter..." 
                          HBox.hgrow="ALWAYS"
                          styleClass="text-field"
                          accessibleText="Search for products or variants to add to the order"/>
                <Button fx:id="addItemButton" text="+ Add Item" onAction="#handleAddItem" 
                       styleClass="action-button, primary-button"
                       accessibleText="Add selected item to order"/>
            </HBox>

            <!-- Items Table -->
            <VBox spacing="5" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Order Summary" styleClass="form-label" style="-fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="itemCountLabel" text="0 items" styleClass="view-subtitle" style="-fx-font-size: 12px;"/>
                </HBox>
                <TableView fx:id="itemsTable" VBox.vgrow="ALWAYS" styleClass="data-table" minHeight="200"
                           accessibleText="List of items in the purchase order">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
        
        <!-- Footer -->
        <HBox alignment="CENTER_RIGHT" spacing="20" styleClass="card">
            <VBox alignment="CENTER_RIGHT" spacing="5">
                <Label text="Total Order Cost:" styleClass="form-label" style="-fx-font-weight: bold;"/>
                <Label fx:id="totalCostLabel" text="\$0.00" style="-fx-font-weight: bold; -fx-font-size: 24px; -fx-text-fill: #2563eb;"/>
            </VBox>
            <Separator orientation="VERTICAL"/>
            <Button text="Cancel" onAction="#handleCancel" styleClass="action-button" cancelButton="true"
                    accessibleText="Cancel purchase order creation"/>
            <Button fx:id="saveButton" text="Save Purchase Order" onAction="#handleSave" styleClass="action-button, primary-button" defaultButton="true"
                    accessibleText="Save purchase order"/>
        </HBox>
    </VBox>
</ScrollPane>
