<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.possum.ui.purchase.PurchaseOrderFormController"
            fitToWidth="true"
            fitToHeight="true"
            stylesheets="@../../styles/inventory.css"
            styleClass="workspace-view"
            style="-fx-background-color: -color-surface;">

    <VBox spacing="20" alignment="TOP_LEFT">
        <!-- Header -->
        <HBox styleClass="view-header">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label fx:id="titleLabel" text="Purchase Order Form" styleClass="view-title"/>
                <Label text="Order new stock from suppliers" styleClass="view-subtitle"/>
            </VBox>
        </HBox>

        <HBox spacing="20" VBox.vgrow="ALWAYS">
            <!-- Left Side: Items Section -->
            <VBox spacing="15" HBox.hgrow="ALWAYS" styleClass="card">
                <Label text="Order Items" styleClass="card-title"/>
                <Label text="Add products to this purchase order" styleClass="view-subtitle" style="-fx-font-size: 12px;"/>

                <!-- Search Bar -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="searchVariantField" 
                              promptText="Search by product name or SKU and press Enter..." 
                              HBox.hgrow="ALWAYS"
                              styleClass="text-field"
                              accessibleText="Search for products or variants to add to the order"/>
                    <Button fx:id="addItemButton" text="+ Add Item" onAction="#handleAddItem" 
                           styleClass="action-button, primary-button"
                           accessibleText="Add selected item to order"/>
                </HBox>

                <!-- Items Table -->
                <VBox spacing="10" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Order Details" styleClass="form-label" style="-fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="itemCountLabel" text="0 items" styleClass="view-subtitle" style="-fx-font-size: 12px;"/>
                    </HBox>
                    <TableView fx:id="itemsTable" VBox.vgrow="ALWAYS" styleClass="data-table" minHeight="400"
                               accessibleText="List of items in the purchase order">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </VBox>

            <!-- Right Side: Sidebar -->
            <VBox spacing="20" maxWidth="380" minWidth="320" HBox.hgrow="NEVER">
                <!-- Supplier Section -->
                <VBox spacing="10" styleClass="card">
                    <Label text="Supplier Information" styleClass="card-title"/>
                    <Label text="Choose the vendor for this order" styleClass="view-subtitle" style="-fx-font-size: 11px;"/>
                    <VBox styleClass="form-group">
                        <Label text="Supplier:" styleClass="form-label" labelFor="$supplierCombo"/>
                        <ComboBox fx:id="supplierCombo" promptText="Choose a supplier" maxWidth="Infinity" styleClass="combo-box"
                                  accessibleText="Select a supplier"/>
                    </VBox>
                </VBox>

                <!-- Payment Method Section -->
                <VBox spacing="10" styleClass="card">
                    <Label text="Payment Information" styleClass="card-title"/>
                    <Label text="Financial details for the transaction" styleClass="view-subtitle" style="-fx-font-size: 11px;"/>
                    <VBox styleClass="form-group">
                        <Label text="Payment Method:" styleClass="form-label" labelFor="$paymentMethodCombo"/>
                        <ComboBox fx:id="paymentMethodCombo" promptText="Choose payment method" maxWidth="Infinity" styleClass="combo-box"
                                  accessibleText="Select the payment method"/>
                    </VBox>
                </VBox>

                <!-- Summary Section -->
                <VBox spacing="20" styleClass="card" VBox.vgrow="ALWAYS">
                    <Label text="Order Summary" styleClass="card-title"/>
                    
                    <VBox spacing="15" VBox.vgrow="ALWAYS">
                        <VBox spacing="5" alignment="CENTER_LEFT">
                            <Label text="Total Payable Amount" styleClass="view-subtitle" style="-fx-font-size: 12px;"/>
                            <Label fx:id="totalCostLabel" text="\$0.00" style="-fx-font-weight: bold; -fx-font-size: 32px; -fx-text-fill: -color-primary;"/>
                        </VBox>
                        
                        <Region VBox.vgrow="ALWAYS"/>

                        <VBox spacing="10">
                            <Button fx:id="saveButton" text="Save Purchase Order" onAction="#handleSave" 
                                    maxWidth="Infinity" styleClass="action-button, primary-button" defaultButton="true"
                                    accessibleText="Save purchase order"/>
                            <Button text="Close" onAction="#handleCancel" 
                                    maxWidth="Infinity" styleClass="action-button" cancelButton="true"
                                    accessibleText="Cancel purchase order"/>
                        </VBox>
                    </VBox>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
