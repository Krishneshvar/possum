<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.possum.ui.common.controls.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.purchase.PurchaseController"
      stylesheets="@../../styles/inventory.css"
      styleClass="workspace-view">

    <!-- Header Section -->
    <VBox>
        <HBox styleClass="view-header">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Purchase Orders" styleClass="view-title"/>
                <Label text="Manage and track your purchase orders from suppliers" styleClass="view-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="⟳ Refresh" onAction="#handleRefresh" styleClass="action-button"
                    accessibleText="Refresh purchase orders list" />
            <Button fx:id="createButton" text="+ New Purchase Order" onAction="#handleCreate" 
                    styleClass="action-button, primary-button" defaultButton="true"
                    accessibleText="Create new purchase order" />
        </HBox>
    </VBox>
    
    <!-- Filters -->
    <FilterBar fx:id="filterBar" styleClass="card"/>
    
    <!-- Data Table -->
    <DataTableView fx:id="purchaseTable" VBox.vgrow="ALWAYS" styleClass="card" />
    
    <!-- Pagination -->
    <PaginationBar fx:id="paginationBar" styleClass="card"/>

</VBox>
