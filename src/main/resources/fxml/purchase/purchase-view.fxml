<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.possum.ui.common.controls.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.purchase.PurchaseController"
      spacing="20"
      alignment="TOP_LEFT">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="Purchase Orders" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="createButton" text="+ Create Purchase Order" onAction="#handleCreate" style="-fx-background-color: #1976d2; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 6;"/>
    </HBox>
    
    <FilterBar fx:id="filterBar"/>
    
    <HBox spacing="15" alignment="CENTER_LEFT">
        <MenuButton text="Status Filter" fx:id="statusMenuButton">
            <items>
                <CheckMenuItem text="Pending" fx:id="statusPendingItem"/>
                <CheckMenuItem text="Received" fx:id="statusReceivedItem"/>
                <CheckMenuItem text="Cancelled" fx:id="statusCancelledItem"/>
            </items>
        </MenuButton>
        <Label text="From:"/>
        <DatePicker fx:id="fromDatePicker" promptText="Start Date"/>
        <Label text="To:"/>
        <DatePicker fx:id="toDatePicker" promptText="End Date"/>
        <Button text="Clear Dates" onAction="#handleClearDates" style="-fx-background-color: transparent; -fx-text-fill: #1976d2; -fx-border-color: transparent; -fx-cursor: hand;"/>
    </HBox>

    <DataTableView fx:id="purchaseTable" VBox.vgrow="ALWAYS"/>
    
    <PaginationBar fx:id="paginationBar"/>

</VBox>
