<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.purchase.PurchaseOrderDetailController"
      spacing="20"
      style="-fx-background-color: #f5f5f5;">
      
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="poNumberLabel" text="PO-0" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                <Label fx:id="statusLabel" style="-fx-font-size: 14px;"/>
            </HBox>
            <Label fx:id="orderDateLabel" text="Order Date" style="-fx-text-fill: gray; -fx-font-size: 12px;"/>
        </VBox>
        <HBox fx:id="actionButtonsBox" spacing="10" alignment="CENTER_RIGHT">
            <Button fx:id="cancelButton" text="✕ Cancel Order" onAction="#handleCancel" 
                   style="-fx-background-color: transparent; -fx-border-color: red; -fx-border-width: 1; -fx-text-fill: red; -fx-padding: 8 16; -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand;"/>
            <Button fx:id="editButton" text="✏ Edit Order" onAction="#handleEdit" 
                   style="-fx-background-color: transparent; -fx-border-color: #1976d2; -fx-border-width: 1; -fx-text-fill: #1976d2; -fx-padding: 8 16; -fx-background-radius: 6; -fx-border-radius: 6; -fx-cursor: hand;"/>
            <Button fx:id="receiveButton" text="✓ Receive Order" onAction="#handleReceive" 
                   style="-fx-background-color: #4caf50; -fx-text-fill: white; -fx-padding: 8 16; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;"/>
            <Button text="Close" onAction="#handleClose" 
                   style="-fx-background-color: #e0e0e0; -fx-text-fill: black; -fx-padding: 8 16; -fx-background-radius: 6; -fx-cursor: hand;"/>
        </HBox>
    </HBox>
    
    <Separator/>
    
    <!-- Main Content -->
    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Items Table -->
        <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 1);">
            <Label text="Items Ordered" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1976d2;"/>
            <TableView fx:id="itemsTable" VBox.vgrow="ALWAYS" 
                      style="-fx-border-color: #e0e0e0; -fx-border-radius: 6; -fx-background-radius: 6;">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
        
        <!-- Sidebar -->
        <VBox spacing="15" prefWidth="280">
            <!-- Supplier Info -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 1);">
                <Label text="Supplier Info" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1976d2;"/>
                <Separator/>
                <VBox spacing="8">
                    <Label text="Supplier Name" style="-fx-text-fill: gray; -fx-font-size: 10px;"/>
                    <Label fx:id="supplierNameLabel" text="Supplier" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                </VBox>
                <Separator/>
                <VBox spacing="8">
                    <Label text="Created By" style="-fx-text-fill: gray; -fx-font-size: 10px;"/>
                    <Label fx:id="createdByLabel" text="User" style="-fx-font-size: 12px;"/>
                </VBox>
                <VBox spacing="8" fx:id="receivedDateBox">
                    <Label text="Received Date" style="-fx-text-fill: gray; -fx-font-size: 10px;"/>
                    <Label fx:id="receivedDateLabel" text="N/A" style="-fx-font-size: 12px;"/>
                </VBox>
            </VBox>
            
            <!-- Order Summary -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 1);">
                <Label text="Order Summary" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1976d2;"/>
                <Separator/>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Total Items:" style="-fx-text-fill: gray; -fx-font-size: 11px;" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="totalItemsLabel" text="0" style="-fx-font-weight: bold;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Total Quantity:" style="-fx-text-fill: gray; -fx-font-size: 11px;" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="totalQuantityLabel" text="0" style="-fx-font-weight: bold;"/>
                </HBox>
                <Separator/>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Total Cost:" style="-fx-font-weight: bold; -fx-font-size: 13px;" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="totalCostLabel" text="\$0.00" style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #1976d2;"/>
                </HBox>
            </VBox>
        </VBox>
    </HBox>
</VBox>
