<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.purchase.PurchaseOrderDetailController"
      stylesheets="@../../styles/inventory.css"
      styleClass="workspace-view">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" styleClass="view-header">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="poNumberLabel" text="PO-0" styleClass="view-title"/>
                <Label fx:id="statusLabel" styleClass="view-subtitle"/>
            </HBox>
            <Label fx:id="orderDateLabel" text="Order Date" styleClass="view-subtitle"/>
        </VBox>
        <HBox fx:id="actionButtonsBox" spacing="10" alignment="CENTER_RIGHT">
            <Button fx:id="cancelButton" text="✕ Cancel Order" onAction="#handleCancel" 
                    styleClass="action-button, danger-button"
                    accessibleText="Cancel this purchase order"/>
            <Button fx:id="editButton" text="✏ Edit Order" onAction="#handleEdit" 
                    styleClass="action-button"
                    accessibleText="Edit this purchase order"/>
            <Button fx:id="receiveButton" text="✓ Receive Order" onAction="#handleReceive" 
                    styleClass="action-button, primary-button" style="-fx-background-color: #10b981;"
                    accessibleText="Mark purchase order as received"/>
            <Button text="Close" onAction="#handleClose" styleClass="action-button" cancelButton="true"
                    accessibleText="Close purchase order details"/>
        </HBox>
    </HBox>
    
    <!-- Main Content -->
    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Items Table -->
        <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="card">
            <Label text="Items Ordered" styleClass="card-title"/>
            <TableView fx:id="itemsTable" VBox.vgrow="ALWAYS" styleClass="data-table"
                       accessibleText="Items ordered in this purchase order">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
        
        <!-- Sidebar -->
        <VBox spacing="20" prefWidth="300" minWidth="300">
            <!-- Supplier Info -->
            <VBox spacing="10" styleClass="card">
                <Label text="Supplier Info" styleClass="card-title"/>
                <Separator/>
                <VBox styleClass="form-group">
                    <Label text="Supplier Name" styleClass="form-label"/>
                    <Label fx:id="supplierNameLabel" text="Supplier" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                </VBox>
                <Separator/>
                <VBox styleClass="form-group">
                    <Label text="Created By" styleClass="form-label"/>
                    <Label fx:id="createdByLabel" text="User" style="-fx-font-size: 13px;"/>
                </VBox>
                <VBox styleClass="form-group" fx:id="receivedDateBox">
                    <Label text="Received Date" styleClass="form-label"/>
                    <Label fx:id="receivedDateLabel" text="N/A" style="-fx-font-size: 13px;"/>
                </VBox>
            </VBox>
            
            <!-- Order Summary -->
            <VBox spacing="10" styleClass="card">
                <Label text="Order Summary" styleClass="card-title"/>
                <Separator/>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Total Items:" styleClass="form-label" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="totalItemsLabel" text="0" style="-fx-font-weight: bold;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Total Quantity:" styleClass="form-label" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="totalQuantityLabel" text="0" style="-fx-font-weight: bold;"/>
                </HBox>
                <Separator/>
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Total Cost:" style="-fx-font-weight: bold; -fx-font-size: 14px;" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="totalCostLabel" text="\$0.00" style="-fx-font-weight: bold; -fx-font-size: 20px; -fx-text-fill: #2563eb;"/>
                </HBox>
            </VBox>
        </VBox>
    </HBox>
</VBox>
