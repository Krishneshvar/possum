<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <top>
        <Label text="Sales / Point of Sale" style="-fx-font-size: 24px; -fx-font-weight: bold;" BorderPane.alignment="CENTER_LEFT">
            <BorderPane.margin>
                <Insets bottom="20"/>
            </BorderPane.margin>
        </Label>
    </top>

    <center>
        <HBox spacing="20">
            <!-- Left: Product Selection -->
            <VBox spacing="15" HBox.hgrow="ALWAYS">
                <TextField promptText="Search products..." prefWidth="400"/>
                
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <VBox spacing="10" style="-fx-padding: 10;">
                        <Label text="No products available" style="-fx-text-fill: #666;"/>
                    </VBox>
                </ScrollPane>
            </VBox>
            
            <!-- Right: Cart -->
            <VBox spacing="15" prefWidth="350" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8;">
                <Label text="Current Sale" style="-fx-font-size: 16px; -fx-font-weight: 600;"/>
                
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <VBox spacing="10">
                        <Label text="Cart is empty" style="-fx-text-fill: #666;"/>
                    </VBox>
                </ScrollPane>
                
                <Separator/>
                
                <HBox alignment="CENTER_LEFT">
                    <Label text="Total:" style="-fx-font-size: 18px; -fx-font-weight: 600;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="\$0.00" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1976d2;"/>
                </HBox>
                
                <Button text="Complete Sale" maxWidth="Infinity" style="-fx-background-color: #1976d2; -fx-text-fill: white; -fx-padding: 15 20; -fx-background-radius: 6; -fx-font-size: 16px;"/>
            </VBox>
        </HBox>
    </center>

</BorderPane>
