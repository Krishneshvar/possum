<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.sales.SaleDetailController"
      styleClass="workspace-view"
      stylesheets="@../../styles/inventory.css">
    
    <!-- Header Section -->
    <HBox styleClass="view-header" alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <HBox spacing="10" alignment="BASELINE_LEFT">
                <Label fx:id="invoiceLabel" text="#INV-001" styleClass="view-title"/>
                <Label fx:id="statusBadge" text="PAID" styleClass="badge-status"/>
            </HBox>
            <Label fx:id="dateLabel" text="Processed on March 25, 2026 at 10:30 AM" styleClass="view-subtitle"/>
        </VBox>
        
        <HBox spacing="10">
            <Button fx:id="printButton" text="Print Receipt" accessibleText="Print Receipt" onAction="#handlePrint" styleClass="action-button">
                <tooltip>
                    <Tooltip text="Print receipt for this sale"/>
                </tooltip>
            </Button>
            <Button fx:id="editButton" text="Edit Bill" accessibleText="Edit Bill" onAction="#handleEdit" styleClass="action-button">
                <tooltip>
                    <Tooltip text="Edit details of this bill"/>
                </tooltip>
            </Button>
            <Button fx:id="returnButton" text="Return Items" accessibleText="Return Items" onAction="#handleReturn" styleClass="action-button, danger-button">
                <tooltip>
                    <Tooltip text="Process a return for items in this bill"/>
                </tooltip>
            </Button>
        </HBox>
    </HBox>

    <Separator/>

    <!-- Customer & Payment Info Cards -->
    <HBox spacing="20">
        <VBox spacing="10" HBox.hgrow="ALWAYS" accessibleText="Customer Details Card" styleClass="card">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="👤" style="-fx-text-fill: #94a3b8;"/>
                <Label text="CUSTOMER DETAILS" styleClass="form-label" style="-fx-font-size: 11;"/>
            </HBox>
            <Label fx:id="customerNameLabel" text="Walk-in Customer" style="-fx-font-size: 16; -fx-font-weight: 700; -fx-text-fill: #0f172a;"/>
            <Label fx:id="customerContactLabel" text="No contact info" style="-fx-text-fill: #475569; -fx-font-size: 13;"/>
        </VBox>
        
        <VBox spacing="10" HBox.hgrow="ALWAYS" accessibleText="Payment Information Card" styleClass="card">
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="💳" style="-fx-text-fill: #94a3b8;"/>
                <Label text="PAYMENT INFO" styleClass="form-label" style="-fx-font-size: 11;"/>
            </HBox>
            <Label fx:id="paymentMethodLabel" text="Cash Payment" style="-fx-font-size: 16; -fx-font-weight: 700; -fx-text-fill: #0f172a;"/>
            <Label fx:id="billerLabel" text="Biller: Admin User" style="-fx-text-fill: #475569; -fx-font-size: 13;"/>
        </VBox>
    </HBox>

    <VBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Active Items Table -->
        <VBox spacing="10" VBox.vgrow="ALWAYS" styleClass="card" style="-fx-padding: 0;">
            <Label text="ITEMIZED BILL" styleClass="form-label" style="-fx-padding: 15 15 5 15; -fx-font-size: 13;"/>
            <com.possum.ui.common.controls.DataTableView fx:id="itemsTable" VBox.vgrow="ALWAYS" />
        </VBox>

        <!-- Returned Items Section (Initially hidden if no returns) -->
        <VBox fx:id="returnedItemsContainer" spacing="10" styleClass="card" style="-fx-padding: 0; -fx-background-color: #fef2f2; -fx-border-color: #fecaca;">
            <Label text="RETURNED ITEMS" styleClass="form-label" style="-fx-padding: 15 15 5 15; -fx-text-fill: #991b1b; -fx-font-size: 13;"/>
            <com.possum.ui.common.controls.DataTableView fx:id="returnedItemsTable" prefHeight="150" style="-fx-background-color: transparent;" />
        </VBox>
    </VBox>

    <!-- Footer Summary Section -->
    <HBox spacing="20" alignment="BOTTOM_RIGHT">
        <GridPane hgap="40" vgap="10" styleClass="card">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" minWidth="100"/>
                <ColumnConstraints halignment="RIGHT" minWidth="120"/>
            </columnConstraints>
            
            <Label text="Subtotal" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #64748b;"/>
            <Label fx:id="subtotalLabel" text="0.00" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-font-weight: 600;"/>
            
            <Label text="Tax total" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #64748b;"/>
            <Label fx:id="taxTotalLabel" text="0.00" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-font-weight: 600;"/>
            
            <Label text="Discount" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #64748b;"/>
            <Label fx:id="discountTotalLabel" text="-0.00" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-font-weight: 600; -fx-text-fill: #ef4444;"/>
            
            <Label text="TOTAL" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: 900; -fx-font-size: 16;"/>
            <Label fx:id="grandTotalLabel" text="0.00" GridPane.columnIndex="1" GridPane.rowIndex="3" style="-fx-font-weight: 900; -fx-font-size: 20; -fx-text-fill: #2563eb;"/>
            
            <Separator GridPane.columnSpan="2" GridPane.rowIndex="4" style="-fx-padding: 5 0;"/>
            
            <Label text="Paid Amount" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-text-fill: #64748b;"/>
            <Label fx:id="paidAmountLabel" text="0.00" GridPane.columnIndex="1" GridPane.rowIndex="5" style="-fx-font-weight: 600;"/>
            
            <Label fx:id="balanceTypeLabel" text="Change" GridPane.columnIndex="0" GridPane.rowIndex="6" style="-fx-text-fill: #64748b;"/>
            <Label fx:id="balanceAmountLabel" text="0.00" GridPane.columnIndex="1" GridPane.rowIndex="6" style="-fx-font-weight: 600;"/>
        </GridPane>
    </HBox>

</VBox>
