<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import com.possum.ui.common.controls.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.sales.SaleDetailController"
      styleClass="workspace-view"
      stylesheets="@../../styles/inventory.css"
      spacing="0">
    
    <!-- Header Section -->
    <HBox styleClass="view-header" alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <HBox spacing="10" alignment="BASELINE_LEFT">
                <Label fx:id="invoiceLabel" text="#INV-001" styleClass="view-title"/>
                <Label fx:id="statusBadge" text="PAID" styleClass="badge-status"/>
            </HBox>
            <Label fx:id="dateLabel" text="Processed on March 25, 2026 at 10:30 AM" styleClass="view-subtitle"/>
        </VBox>
        
        <HBox spacing="10">
            <Button fx:id="printButton" text="Print Receipt" accessibleText="Print Receipt" onAction="#handlePrint" styleClass="action-button">
                <graphic>
                    <FontIcon iconLiteral="fas-print" iconSize="16"/>
                </graphic>
                <tooltip>
                    <Tooltip text="Print receipt for this sale"/>
                </tooltip>
            </Button>
            <Button fx:id="editButton" text="Edit Bill" accessibleText="Edit Bill" onAction="#handleEdit" styleClass="action-button">
                <graphic>
                    <FontIcon iconLiteral="fas-pencil-alt" iconSize="16"/>
                </graphic>
                <tooltip>
                    <Tooltip text="Edit details of this bill"/>
                </tooltip>
            </Button>
            <Button fx:id="returnButton" text="Return Items" accessibleText="Return Items" onAction="#handleReturn" styleClass="action-button, danger-button" style="-fx-border-color: #EF4444; -fx-border-width: 1;">
                <graphic>
                    <FontIcon iconLiteral="fas-undo" iconSize="16" iconColor="#EF4444"/>
                </graphic>
                <tooltip>
                    <Tooltip text="Process a return for items in this bill"/>
                </tooltip>
            </Button>
        </HBox>
    </HBox>

    <Separator/>

    <!-- Main Content Area: Left (Table) and Right (Info Sidebar) -->
    <HBox spacing="20" VBox.vgrow="ALWAYS" style="-fx-padding: 0 0 20 0;">
        
        <!-- Left Section: Bill Items -->
        <VBox spacing="20" HBox.hgrow="ALWAYS">
            <VBox spacing="0" VBox.vgrow="ALWAYS" styleClass="card" style="-fx-padding: 0;">
                <Label text="ITEMIZED BILL" styleClass="form-label" style="-fx-padding: 15 20 10 20; -fx-font-size: 13;"/>
                <DataTableView fx:id="itemsTable" VBox.vgrow="ALWAYS" />
            </VBox>

            <!-- Refunded Items (Dynamic) -->
            <VBox fx:id="returnedItemsContainer" spacing="0" styleClass="card" style="-fx-padding: 0; -fx-background-color: #fef2f2; -fx-border-color: #fecaca;">
                <Label text="RETURNED ITEMS" styleClass="form-label" style="-fx-padding: 15 20 10 20; -fx-text-fill: #991b1b; -fx-font-size: 13;"/>
                <DataTableView fx:id="returnedItemsTable" prefHeight="200" style="-fx-background-color: transparent;" />
            </VBox>
        </VBox>

        <!-- Right Section: Sidebar Information -->
        <VBox spacing="20" minWidth="350" prefWidth="350" maxWidth="400">
            <!-- Customer Details -->
            <VBox spacing="10" styleClass="card">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <FontIcon iconLiteral="fas-user" iconSize="14" iconColor="#94a3b8"/>
                    <Label text="CUSTOMER DETAILS" styleClass="form-label" style="-fx-font-size: 11;"/>
                </HBox>
                <Label fx:id="customerNameLabel" text="Walk-in Customer" style="-fx-font-size: 16; -fx-font-weight: 700; -fx-text-fill: #0f172a;"/>
                <Label fx:id="customerContactLabel" text="No contact info" style="-fx-text-fill: #475569; -fx-font-size: 13;"/>
            </VBox>

            <!-- Payment Info -->
            <VBox spacing="10" styleClass="card">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="💳" style="-fx-text-fill: #94a3b8;"/>
                    <Label text="PAYMENT INFO" styleClass="form-label" style="-fx-font-size: 11;"/>
                </HBox>
                <Label fx:id="paymentMethodLabel" text="Cash Payment" style="-fx-font-size: 16; -fx-font-weight: 700; -fx-text-fill: #0f172a;"/>
                <Label fx:id="billerLabel" text="Biller: Admin User" style="-fx-text-fill: #475569; -fx-font-size: 13;"/>
            </VBox>

            <!-- Order Summary Sidebar -->
            <VBox spacing="15" styleClass="card" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="📋" style="-fx-text-fill: #94a3b8;"/>
                    <Label text="ORDER SUMMARY" styleClass="form-label" style="-fx-font-size: 11;"/>
                </HBox>
                
                <VBox spacing="8">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Subtotal" style="-fx-text-fill: #64748b;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Label fx:id="subtotalLabel" text="0.00" style="-fx-font-weight: 600;"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Tax Total" style="-fx-text-fill: #64748b;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Label fx:id="taxTotalLabel" text="0.00" style="-fx-font-weight: 600;"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Discount" style="-fx-text-fill: #64748b;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Label fx:id="discountTotalLabel" text="-0.00" style="-fx-font-weight: 600; -fx-text-fill: #ef4444;"/>
                    </HBox>
                    
                    <Separator style="-fx-padding: 10 0;"/>
                    
                    <HBox alignment="CENTER_LEFT">
                        <Label text="TOTAL" style="-fx-font-weight: 900; -fx-font-size: 14;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Label fx:id="grandTotalLabel" text="0.00" style="-fx-font-weight: 900; -fx-font-size: 22; -fx-text-fill: #3b82f6;"/>
                    </HBox>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <VBox spacing="8" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 6; -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 6;">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Paid Amount" style="-fx-text-fill: #64748b;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Label fx:id="paidAmountLabel" text="0.00" style="-fx-font-weight: 600;"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT">
                        <Label fx:id="balanceTypeLabel" text="Change" style="-fx-text-fill: #64748b;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Label fx:id="balanceAmountLabel" text="0.00" style="-fx-font-weight: 600;"/>
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </HBox>
</VBox>
