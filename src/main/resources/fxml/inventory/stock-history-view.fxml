<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.possum.ui.common.controls.PaginationBar?>

<VBox fx:id="container" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.inventory.StockHistoryController"
      styleClass="workspace-view"
      stylesheets="@../../styles/inventory.css">

    <!-- Header Area -->
    <HBox styleClass="view-header" alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="4">
            <Label text="Stock Activity Log" styleClass="view-title" accessibleRole="TEXT"/>
            <Label text="Review a comprehensive audit trail of all manual adjustments and stock movements." styleClass="view-subtitle" accessibleRole="TEXT"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button fx:id="refreshButton" text="↺ Refresh Activity" onAction="#handleRefresh" styleClass="action-button, primary-button" accessibleText="Refresh stock history list" accessibleRole="BUTTON" defaultButton="true">
                <tooltip>
                    <Tooltip text="Fetch the latest historical records from the database"/>
                </tooltip>
            </Button>
        </HBox>
    </HBox>

    <!-- Data Table -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <TableView fx:id="historyTable" VBox.vgrow="ALWAYS" styleClass="data-table" accessibleRole="TABLE_VIEW" accessibleText="Stock History Table">
            <columns>
                <TableColumn fx:id="productCol" text="Product" prefWidth="150"/>
                <TableColumn fx:id="variantCol" text="Variant" prefWidth="150"/>
                <TableColumn fx:id="skuCol" text="SKU" prefWidth="120"/>
                <TableColumn fx:id="changeCol" text="Change" prefWidth="80" style="-fx-alignment: CENTER-RIGHT;"/>
                <TableColumn fx:id="reasonCol" text="Reason" prefWidth="150"/>
                <TableColumn fx:id="adjustedByCol" text="Adjusted By" prefWidth="150"/>
                <TableColumn fx:id="dateCol" text="Date &amp; Time" prefWidth="150"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
        <PaginationBar fx:id="paginationBar"/>
    </VBox>
</VBox>
