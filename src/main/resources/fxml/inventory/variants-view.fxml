<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.possum.ui.common.controls.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.inventory.VariantsController"
      styleClass="workspace-view"
      stylesheets="@../../styles/inventory.css">

    <!-- Header Area -->
    <HBox styleClass="view-header" alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="4">
            <Label text="Product Variants Library" styleClass="view-title" accessibleRole="TEXT"/>
            <Label text="Browse and filter specific variations of products, view SKUs, and track unique properties." styleClass="view-subtitle" accessibleRole="TEXT"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button fx:id="refreshButton" text="↺ Reload Variants" onAction="#handleRefresh" styleClass="action-button, primary-button" accessibleText="Refresh variants table" accessibleRole="BUTTON" defaultButton="true">
                <tooltip>
                    <Tooltip text="Reload all variants from the database"/>
                </tooltip>
            </Button>
        </HBox>
    </HBox>

    <!-- Main Content -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <FilterBar fx:id="filterBar"/>

        <HBox alignment="CENTER_RIGHT" spacing="8" styleClass="view-mode-toggle-row">
            <Label text="View:" styleClass="helper-text"/>
            <ToggleButton fx:id="cardsViewButton" text="Cards" styleClass="toggle-btn-neon" selected="true"/>
            <ToggleButton fx:id="tableViewButton" text="Table" styleClass="toggle-btn-neon"/>
        </HBox>

        <StackPane VBox.vgrow="ALWAYS">
            <ScrollPane fx:id="variantsGridScroll" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="product-grid-scroll">
                <content>
                    <FlowPane fx:id="variantsGrid" hgap="16" vgap="16" prefWrapLength="1200" styleClass="product-grid">
                        <padding>
                            <Insets top="8" right="4" bottom="8" left="4"/>
                        </padding>
                    </FlowPane>
                </content>
            </ScrollPane>

            <DataTableView fx:id="variantsTable" VBox.vgrow="ALWAYS" styleClass="data-table" visible="false" managed="false"/>
        </StackPane>

        <PaginationBar fx:id="paginationBar"/>
    </VBox>

</VBox>
