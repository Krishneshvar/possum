<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.possum.ui.common.controls.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.inventory.VariantsController"
      styleClass="workspace-view"
      stylesheets="@../../styles/inventory.css">

    <!-- Header -->
    <HBox styleClass="view-header" alignment="CENTER_LEFT">
        <VBox>
            <Label text="Variants" styleClass="view-title"/>
            <Label text="Manage all item variations" styleClass="view-subtitle"/>
        </VBox>
    </HBox>

    <!-- Main Content -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <FilterBar fx:id="filterBar"/>

        <DataTableView fx:id="variantsTable" VBox.vgrow="ALWAYS" styleClass="data-table"/>

        <PaginationBar fx:id="paginationBar"/>
    </VBox>

</VBox>
