<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.possum.ui.common.controls.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.inventory.VariantsController"
      styleClass="workspace-view"
      stylesheets="@../../styles/inventory.css">

    <!-- Header Area -->
    <HBox styleClass="view-header" alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="4">
            <Label text="Product Variants Library" styleClass="view-title" accessibleRole="TEXT"/>
            <Label text="Browse and filter specific variations of products, view SKUs, and track unique properties." styleClass="view-subtitle" accessibleRole="TEXT"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button fx:id="refreshButton" text="Reload Variants" onAction="#handleRefresh" styleClass="action-button" accessibleText="Refresh variants table" accessibleRole="BUTTON">
                <graphic><FontIcon iconLiteral="bx-sync" iconSize="16"/></graphic>
                <tooltip>
                    <Tooltip text="Reload all variants from the database"/>
                </tooltip>
            </Button>
        </HBox>
    </HBox>

    <!-- Main Content -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <FilterBar fx:id="filterBar"/>

        <StackPane VBox.vgrow="ALWAYS">
            <DataTableView fx:id="variantsTable" VBox.vgrow="ALWAYS" styleClass="data-table"/>
        </StackPane>

        <PaginationBar fx:id="paginationBar"/>
    </VBox>

</VBox>
