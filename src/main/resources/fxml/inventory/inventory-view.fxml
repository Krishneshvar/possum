<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.possum.ui.common.controls.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.inventory.InventoryController"
      styleClass="workspace-view"
      stylesheets="@../../styles/inventory.css">

    <!-- Header Area -->
    <HBox styleClass="view-header" alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="4">
            <Label text="Live Inventory Status" styleClass="view-title" accessibleRole="TEXT"/>
            <Label text="Monitor real-time stock levels, check availability statuses, and perform quick adjustments." styleClass="view-subtitle" accessibleRole="TEXT"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button fx:id="refreshButton" text="↺ Sync Inventory Data" onAction="#handleRefresh" styleClass="action-button, primary-button" accessibleText="Refresh inventory list" accessibleRole="BUTTON" defaultButton="true">
                <tooltip>
                    <Tooltip text="Fetch the latest stock levels from the database"/>
                </tooltip>
            </Button>
        </HBox>
    </HBox>
    
    <!-- Main Content -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <FilterBar fx:id="filterBar"/>

        <DataTableView fx:id="inventoryTable" VBox.vgrow="ALWAYS" styleClass="data-table"/>

        <PaginationBar fx:id="paginationBar"/>
    </VBox>

</VBox>
