<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.possum.ui.common.controls.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.inventory.InventoryController"
      styleClass="workspace-view"
      stylesheets="@../../styles/inventory.css">

    <!-- Header -->
    <HBox styleClass="view-header" alignment="CENTER_LEFT">
        <VBox>
            <Label text="Inventory" styleClass="view-title"/>
            <Label text="Monitor stock levels and statuses across all products" styleClass="view-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="refreshButton" text="Refresh" onAction="#handleRefresh" styleClass="action-button">
            <tooltip>
                <Tooltip text="Refresh the inventory list"/>
            </tooltip>
        </Button>
    </HBox>
    
    <!-- Main Content -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <FilterBar fx:id="filterBar"/>

        <DataTableView fx:id="inventoryTable" VBox.vgrow="ALWAYS" styleClass="data-table"/>

        <PaginationBar fx:id="paginationBar"/>
    </VBox>

</VBox>
