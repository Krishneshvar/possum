<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.possum.ui.common.controls.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.transactions.TransactionsController"
      styleClass="workspace-view"
      stylesheets="@../../styles/inventory.css">
    
    <!-- Header Area -->
    <HBox styleClass="view-header" alignment="CENTER_LEFT">
        <VBox>
            <Label text="Transactions" styleClass="view-title"/>
            <Label text="Monitor financial movements including sales, refunds, and payments" styleClass="view-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="↺ Refresh" accessibleText="Refresh Transactions List" onAction="#handleRefresh" styleClass="action-button">
                <tooltip>
                    <Tooltip text="Refresh the transactions list"/>
                </tooltip>
            </Button>
        </HBox>
    </HBox>
    
    <VBox VBox.vgrow="ALWAYS" styleClass="card">
        <FilterBar fx:id="filterBar"/>
        
        <DataTableView fx:id="transactionsTable" VBox.vgrow="ALWAYS"/>
        
        <PaginationBar fx:id="paginationBar"/>
    </VBox>

</VBox>
