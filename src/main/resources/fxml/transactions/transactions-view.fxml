<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.possum.ui.common.controls.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.transactions.TransactionsController"
      spacing="20"
      alignment="TOP_LEFT">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="Transactions" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🔄 Refresh" accessibleText="Refresh Transactions List" onAction="#handleRefresh" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-padding: 8 16; -fx-font-weight: 600; -fx-cursor: hand; -fx-text-fill: #0f172a;">
            <tooltip>
                <Tooltip text="Refresh the transactions list"/>
            </tooltip>
        </Button>
    </HBox>
    
    <FilterBar fx:id="filterBar"/>
    
    <DataTableView fx:id="transactionsTable" VBox.vgrow="ALWAYS"/>
    
    <PaginationBar fx:id="paginationBar"/>

</VBox>
