<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.settings.tax.TaxSimulatorController"
      spacing="20"
      style="-fx-padding: 20 0 0 0;"
      stylesheets="@../../styles/inventory.css">

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Left Side: Simulator Configuration -->
        <VBox spacing="15" styleClass="card" style="-fx-min-width: 400; -fx-max-width: 400;">
            <VBox spacing="5">
                <Label text="Tax Simulator Engine" styleClass="card-title"/>
                <Label text="Test tax rules by simulating an invoice item" style="-fx-text-fill: #64748b;"/>
            </VBox>
            
            <Separator/>
            
            <VBox spacing="20" VBox.vgrow="ALWAYS">
                <VBox styleClass="form-group">
                    <Label text="Unit Price *" styleClass="form-label"/>
                    <TextField fx:id="amountField" promptText="e.g. 100.00" styleClass="text-field" accessibleText="Unit Price Amount"/>
                </VBox>

                <VBox styleClass="form-group">
                    <Label text="Quantity *" styleClass="form-label"/>
                    <TextField fx:id="quantityField" promptText="e.g. 1" styleClass="text-field" accessibleText="Item Quantity"/>
                </VBox>

                <VBox styleClass="form-group">
                    <Label text="Target Tax Category *" styleClass="form-label"/>
                    <ComboBox fx:id="categoryCombo" maxWidth="Infinity" styleClass="combo-box" accessibleText="Select Target Tax Category"/>
                </VBox>
            </VBox>
            
            <Separator/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Reset Form" onAction="#handleClear" styleClass="action-button" accessibleText="Reset Simulator Form" cancelButton="true"/>
                <Button fx:id="calculateButton" text="Run Calculation" onAction="#handleCalculate" styleClass="primary-button"
                        defaultButton="true" accessibleText="Calculate Tax Results"/>
            </HBox>
        </VBox>

        <!-- Right Side: Simulation Results -->
        <VBox spacing="10" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" styleClass="card">
            <Label text="Execution Results" styleClass="card-title"/>

            <TextArea fx:id="resultArea" VBox.vgrow="ALWAYS" editable="false"
                      styleClass="text-area"
                      style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 13px; -fx-background-color: #f8fafc;"
                      promptText="Ready. Set parameters and click 'Run Calculation' to view the generated tax breakdown..."/>
        </VBox>
    </HBox>

</VBox>
