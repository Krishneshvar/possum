<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.settings.tax.TaxManagementController"
      styleClass="workspace-view"
      stylesheets="@../../../styles/settings.css">

    <VBox styleClass="view-header">
        <Label text="Tax Configuration" styleClass="view-title"/>
        <Label text="Configure tax profiles, categories, tax rules, and test calculations using the simulator." styleClass="view-subtitle"/>
    </VBox>
    
    <TabPane fx:id="taxTabPane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE" styleClass="settings-tab-pane">
        <Tab text="Profiles" closable="false">
            <fx:include source="tax-profiles.fxml" fx:id="taxProfiles"/>
        </Tab>
        <Tab text="Categories" closable="false">
            <fx:include source="tax-categories.fxml" fx:id="taxCategories"/>
        </Tab>
        <Tab text="Rules" closable="false">
            <fx:include source="tax-rules.fxml" fx:id="taxRules"/>
        </Tab>
        <Tab text="Simulator" closable="false">
            <fx:include source="tax-simulator.fxml" fx:id="taxSimulator"/>
        </Tab>
    </TabPane>

</VBox>
