<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.possum.ui.common.controls.DataTableView?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.settings.tax.TaxRulesController"
      spacing="20"
      style="-fx-padding: 20 0 0 0;"
      stylesheets="@../../../styles/settings.css">


    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Left Side: Table of Rules -->
        <VBox spacing="10" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" styleClass="card" style="-fx-min-width: 400;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Tax Rules List" styleClass="card-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Profile:" styleClass="form-label" style="-fx-font-weight: 700;"/>
                <ComboBox fx:id="profileCombo" prefWidth="250" styleClass="combo-box" accessibleText="Select Tax Profile"/>
                <Label fx:id="profileErrorLabel" text="" styleClass="field-error" visible="false" managed="false"/>
            </HBox>
            <DataTableView fx:id="rulesTable" VBox.vgrow="ALWAYS" />
        </VBox>

        <!-- Right Side: Rule Details Form -->
        <VBox spacing="15" styleClass="form-section" style="-fx-min-width: 480; -fx-max-width: 480;">
            <Label text="Rule Configuration" styleClass="form-section-title"/>
            <Label text="Create or edit tax rules with conditional constraints and effective date range." styleClass="form-section-subtitle"/>
            
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="rule-editor-scroll" style="-fx-padding: 0;">
                <VBox spacing="20" style="-fx-padding: 0 5 0 0;">

                    <!-- Basic Config -->
                    <VBox spacing="15">
                        <Label text="Basic Details" styleClass="form-section-title"/>
                        <HBox spacing="10">
                            <VBox styleClass="form-group" HBox.hgrow="ALWAYS">
                                <Label text="Tax Category" styleClass="form-label"/>
                                <ComboBox fx:id="categoryCombo" maxWidth="Infinity" styleClass="combo-box" accessibleText="Tax Category"/>
                            </VBox>
                            <VBox styleClass="form-group" HBox.hgrow="ALWAYS">
                                <HBox spacing="4">
                                    <Label text="Tax Scope" styleClass="form-label"/>
                                    <Label text="*" styleClass="required-indicator"/>
                                </HBox>
                                <ComboBox fx:id="scopeCombo" maxWidth="Infinity" styleClass="combo-box" accessibleText="Tax Scope"/>
                                <Label fx:id="scopeErrorLabel" text="" styleClass="field-error" visible="false" managed="false"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="10">
                            <VBox styleClass="form-group" HBox.hgrow="ALWAYS">
                                <HBox spacing="4">
                                    <Label text="Rate (%)" styleClass="form-label"/>
                                    <Label text="*" styleClass="required-indicator"/>
                                </HBox>
                                <TextField fx:id="rateField" promptText="e.g., 18" styleClass="text-field" accessibleText="Tax Rate Percentage"/>
                                <Label fx:id="rateErrorLabel" text="" styleClass="field-error" visible="false" managed="false"/>
                            </VBox>
                            <VBox styleClass="form-group" HBox.hgrow="ALWAYS">
                                <Label text="Priority Level" styleClass="form-label"/>
                                <TextField fx:id="priorityField" promptText="0" styleClass="text-field" accessibleText="Execution Priority"/>
                                <Label fx:id="priorityErrorLabel" text="" styleClass="field-error" visible="false" managed="false"/>
                            </VBox>
                        </HBox>

                        <CheckBox fx:id="compoundCheckBox" text="Compound Tax (Calculated on top of previous taxes)" styleClass="check-box" accessibleText="Is Compound Tax"/>
                    </VBox>

                    <Separator/>

                    <!-- Advanced Constraints -->
                    <VBox spacing="15">
                        <Label text="Conditional Constraints (Optional)" styleClass="form-section-title"/>
                        <Label text="Apply this tax only if these conditions are met" styleClass="field-helper"/>

                        <HBox spacing="10">
                            <VBox styleClass="form-group" HBox.hgrow="ALWAYS">
                                <Label text="Min Item Price" styleClass="form-label"/>
                                <TextField fx:id="minPriceField" promptText="Optional" styleClass="text-field"/>
                                <Label fx:id="minPriceErrorLabel" text="" styleClass="field-error" visible="false" managed="false"/>
                            </VBox>
                            <VBox styleClass="form-group" HBox.hgrow="ALWAYS">
                                <Label text="Max Item Price" styleClass="form-label"/>
                                <TextField fx:id="maxPriceField" promptText="Optional" styleClass="text-field"/>
                                <Label fx:id="maxPriceErrorLabel" text="" styleClass="field-error" visible="false" managed="false"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="10">
                            <VBox styleClass="form-group" HBox.hgrow="ALWAYS">
                                <Label text="Min Invoice Total" styleClass="form-label"/>
                                <TextField fx:id="minInvoiceField" promptText="Optional" styleClass="text-field"/>
                                <Label fx:id="minInvoiceErrorLabel" text="" styleClass="field-error" visible="false" managed="false"/>
                            </VBox>
                            <VBox styleClass="form-group" HBox.hgrow="ALWAYS">
                                <Label text="Max Invoice Total" styleClass="form-label"/>
                                <TextField fx:id="maxInvoiceField" promptText="Optional" styleClass="text-field"/>
                                <Label fx:id="maxInvoiceErrorLabel" text="" styleClass="field-error" visible="false" managed="false"/>
                            </VBox>
                        </HBox>

                        <VBox styleClass="form-group">
                            <Label text="Customer Type Constraint" styleClass="form-label"/>
                            <TextField fx:id="customerTypeField" promptText="Optional" styleClass="text-field"/>
                        </VBox>

                        <HBox spacing="10">
                            <VBox styleClass="form-group" HBox.hgrow="ALWAYS">
                                <Label text="Valid From Date" styleClass="form-label"/>
                                <DatePicker fx:id="validFromPicker" maxWidth="Infinity" styleClass="date-picker"/>
                            </VBox>
                            <VBox styleClass="form-group" HBox.hgrow="ALWAYS">
                                <Label text="Valid To Date" styleClass="form-label"/>
                                <DatePicker fx:id="validToPicker" maxWidth="Infinity" styleClass="date-picker"/>
                            </VBox>
                        </HBox>
                        <Label fx:id="dateRangeErrorLabel" text="" styleClass="field-error" visible="false" managed="false"/>
                    </VBox>

                </VBox>
            </ScrollPane>
            
            <Separator/>
            
            <HBox spacing="10" style="-fx-padding: 10 0 0 0;" styleClass="form-actions">
                <Button text="Delete" fx:id="deleteButton" onAction="#handleDelete" styleClass="action-button" style="-fx-border-color: -color-error; -fx-border-width: 1; -fx-text-fill: -color-error;" accessibleText="Delete selected rule" maxWidth="Infinity" HBox.hgrow="ALWAYS">
                    <graphic><FontIcon iconLiteral="bx-trash" iconSize="16" iconColor="#EF4444"/></graphic>
                </Button>
                <Button text="Update" fx:id="updateButton" onAction="#handleUpdate" styleClass="action-button" accessibleText="Update selected rule" maxWidth="Infinity" HBox.hgrow="ALWAYS">
                    <graphic><FontIcon iconLiteral="bx-edit" iconSize="16"/></graphic>
                </Button>
                <Button text="Add Rule" fx:id="addButton" onAction="#handleAdd" styleClass="primary-button" accessibleText="Add new rule" defaultButton="true" maxWidth="Infinity" HBox.hgrow="ALWAYS">
                    <graphic><FontIcon iconLiteral="bx-plus" iconSize="16" iconColor="white"/></graphic>
                </Button>
            </HBox>
        </VBox>
    </HBox>

</VBox>
