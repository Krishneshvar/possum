<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.settings.tax.TaxCategoriesController"
      spacing="20"
      style="-fx-padding: 20 0 0 0;"
      stylesheets="@../../styles/inventory.css">

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Left Side: Categories Table -->
        <VBox spacing="10" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" styleClass="card">
            <Label text="Tax Categories List" styleClass="card-title"/>
            <TableView fx:id="categoriesTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                <placeholder>
                    <Label text="No tax categories found. Add a new category to link it with products." style="-fx-text-fill: #94a3b8;"/>
                </placeholder>
                <columns>
                    <TableColumn fx:id="nameColumn" text="Category Name" prefWidth="200"/>
                    <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="350"/>
                    <TableColumn fx:id="productCountColumn" text="Products Assigned" prefWidth="120"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>

        <!-- Right Side: Category Details Form -->
        <VBox spacing="15" styleClass="card" style="-fx-min-width: 400; -fx-max-width: 400;">
            <Label text="Category Details" styleClass="card-title"/>

            <VBox spacing="15" VBox.vgrow="ALWAYS">
                <VBox styleClass="form-group">
                    <Label text="Category Name *" styleClass="form-label"/>
                    <TextField fx:id="nameField" promptText="e.g., Standard Rate" styleClass="text-field" accessibleText="Category Name"/>
                </VBox>

                <VBox styleClass="form-group">
                    <Label text="Description" styleClass="form-label"/>
                    <TextArea fx:id="descriptionArea" prefRowCount="4" promptText="Optional description of when to apply this tax rate"
                              styleClass="text-area" wrapText="true" accessibleText="Category Description"/>
                </VBox>
            </VBox>

            <Separator/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Clear" onAction="#handleClear" styleClass="action-button" accessibleText="Clear form fields" cancelButton="true"/>
                <Button text="Delete" onAction="#handleDelete" styleClass="danger-button" accessibleText="Delete selected category"/>
                <Button text="Update" onAction="#handleUpdate" styleClass="action-button" accessibleText="Update selected category"/>
                <Button text="Add Category" onAction="#handleAdd" styleClass="primary-button" accessibleText="Add new category" defaultButton="true"/>
            </HBox>
        </VBox>
    </HBox>

</VBox>
