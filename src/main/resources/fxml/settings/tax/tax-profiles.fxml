<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.settings.tax.TaxProfilesController"
      spacing="20"
      style="-fx-padding: 20 0 0 0;"
      stylesheets="@../../styles/inventory.css">

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Left Side: Table of Profiles -->
        <VBox spacing="10" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS" styleClass="card">
            <Label text="Tax Profiles List" styleClass="card-title"/>
            <TableView fx:id="profilesTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                <placeholder>
                    <Label text="No tax profiles created yet. Create one from the details pane." style="-fx-text-fill: #94a3b8;"/>
                </placeholder>
                <columns>
                    <TableColumn fx:id="nameColumn" text="Profile Name" prefWidth="250"/>
                    <TableColumn fx:id="regionColumn" text="Region Code" prefWidth="120"/>
                    <TableColumn fx:id="modeColumn" text="Pricing Mode" prefWidth="150"/>
                    <TableColumn fx:id="statusColumn" text="Active Status" prefWidth="120"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>

        <!-- Right Side: Details Form -->
        <VBox spacing="15" styleClass="card" style="-fx-min-width: 400; -fx-max-width: 400;">
            <Label text="Profile Details" styleClass="card-title"/>

            <VBox spacing="15" VBox.vgrow="ALWAYS">
                <VBox styleClass="form-group">
                    <Label text="Profile Name *" styleClass="form-label"/>
                    <TextField fx:id="nameField" promptText="e.g., GST India" styleClass="text-field" accessibleText="Profile Name"/>
                </VBox>

                <HBox spacing="10">
                    <VBox styleClass="form-group" HBox.hgrow="ALWAYS">
                        <Label text="Country Code *" styleClass="form-label"/>
                        <TextField fx:id="countryCodeField" promptText="e.g., IN" styleClass="text-field" accessibleText="Country Code"/>
                    </VBox>
                    <VBox styleClass="form-group" HBox.hgrow="ALWAYS">
                        <Label text="Region Code" styleClass="form-label"/>
                        <TextField fx:id="regionCodeField" promptText="Optional" styleClass="text-field" accessibleText="Region Code"/>
                    </VBox>
                </HBox>

                <VBox styleClass="form-group">
                    <Label text="Pricing Mode" styleClass="form-label"/>
                    <ComboBox fx:id="pricingModeCombo" maxWidth="Infinity" styleClass="combo-box" accessibleText="Pricing Mode"/>
                    <Label text="Determines if product prices include tax" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                </VBox>

                <VBox style="-fx-padding: 10 0 0 0;">
                    <CheckBox fx:id="activeCheckBox" text="Set as Active System Profile" styleClass="check-box" accessibleText="Set as active system profile"/>
                </VBox>
            </VBox>

            <Separator/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Clear" onAction="#handleClear" styleClass="action-button" accessibleText="Clear form fields" cancelButton="true"/>
                <Button text="Delete" onAction="#handleDelete" styleClass="danger-button" accessibleText="Delete selected profile"/>
                <Button text="Update" onAction="#handleUpdate" styleClass="action-button" accessibleText="Update selected profile"/>
                <Button text="Add Profile" onAction="#handleAdd" styleClass="primary-button" accessibleText="Add new profile" defaultButton="true"/>
            </HBox>
        </VBox>
    </HBox>

</VBox>
