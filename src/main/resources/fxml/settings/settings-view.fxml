<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.settings.SettingsController"
      styleClass="workspace-view"
      stylesheets="@../../styles/settings.css">
    
    <VBox styleClass="view-header">
        <Label text="System Settings" styleClass="view-title"/>
        <Label text="Manage general, billing, printing, and tax settings." styleClass="view-subtitle"/>
    </VBox>
    
    <TabPane VBox.vgrow="ALWAYS" styleClass="settings-tab-pane">
        <Tab text="General" closable="false">
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 16 0 0 0;">
                <VBox spacing="20">
                    <VBox styleClass="card">
                        <Label text="Store Profile" styleClass="card-title"/>
                        <VBox styleClass="form-group">
                            <Label text="Store Name" styleClass="form-label"/>
                            <TextField fx:id="storeNameField" prefWidth="400" maxWidth="400"
                                       styleClass="text-field" accessibleText="Store Name"/>
                        </VBox>
                        <VBox styleClass="form-group">
                            <Label text="System Currency" styleClass="form-label"/>
                            <ComboBox fx:id="currencyCombo" prefWidth="400" maxWidth="400"
                                      styleClass="combo-box" accessibleText="System Currency"/>
                            <Label text="Used for financial reports and default billing" styleClass="field-helper"/>
                        </VBox>
                        <VBox styleClass="form-group">
                            <Label text="Date Format" styleClass="form-label"/>
                            <ComboBox fx:id="dateFormatCombo" prefWidth="400" maxWidth="400"
                                      styleClass="combo-box" accessibleText="Date Format"/>
                            <Label text="Format for displaying dates across the app" styleClass="field-helper"/>
                        </VBox>
                        <VBox styleClass="form-group">
                            <Label text="Time Format" styleClass="form-label"/>
                            <ComboBox fx:id="timeFormatCombo" prefWidth="400" maxWidth="400"
                                      styleClass="combo-box" accessibleText="Time Format"/>
                            <Label text="Format for displaying times across the app" styleClass="field-helper"/>
                        </VBox>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Button text="Save Settings" onAction="#handleSaveGeneral" styleClass="primary-button"
                                    defaultButton="true" accessibleText="Save Settings">
                                <graphic><FontIcon iconLiteral="bx-save" iconSize="16" iconColor="white"/></graphic>
                            </Button>
                        </HBox>
                    </VBox>
                </VBox>
            </ScrollPane>
        </Tab>
        
        <Tab text="Bill Structure" closable="false">
            <AnchorPane fx:id="billSettingsTabContent"/>
        </Tab>
        
        <Tab text="Hardware &amp; Printing" closable="false">
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 16 0 0 0;">
                <VBox spacing="20">
                    <VBox styleClass="card">
                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <VBox HBox.hgrow="ALWAYS">
                                <Label text="Receipt Printer" styleClass="card-title"/>
                                <Label text="Select default printer for POS receipts" styleClass="field-helper"/>
                            </VBox>
                            <Button text="Refresh Printers" onAction="#handleRefreshPrinters" styleClass="action-button"
                                    accessibleText="Refresh connected printers list">
                                <graphic><FontIcon iconLiteral="bx-sync" iconSize="16"/></graphic>
                            </Button>
                        </HBox>
                        <Separator/>
                        <VBox styleClass="form-group" spacing="15">
                            <VBox spacing="5">
                                <Label text="Selected Printer" styleClass="form-label"/>
                                <ComboBox fx:id="printerCombo" prefWidth="400" maxWidth="400" styleClass="combo-box"
                                          accessibleText="Select Default Printer"/>
                            </VBox>
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Button fx:id="testPrintBtn" text="Test Print" onAction="#handleTestPrint" styleClass="action-button" accessibleText="Send a test print to selected printer">
                                    <graphic><FontIcon iconLiteral="bx-printer" iconSize="16"/></graphic>
                                </Button>
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>
            </ScrollPane>
        </Tab>
        
        <Tab text="Tax Config" closable="false">
            <AnchorPane fx:id="taxSettingsTabContent"/>
        </Tab>
    </TabPane>

</VBox>
