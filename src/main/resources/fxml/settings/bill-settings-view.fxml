<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      spacing="20"
      styleClass="workspace-view"
      stylesheets="@../../styles/settings.css">

    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="view-header">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Bill &amp; Receipt Structure" styleClass="view-title"/>
            <Label text="Customize the thermal receipt layout and formatting" styleClass="view-subtitle"/>
        </VBox>
        <Button fx:id="saveButton" text="Save Changes" onAction="#handleSave" 
                styleClass="primary-button" defaultButton="true" accessibleText="Save Bill Settings"/>
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <VBox spacing="15" HBox.hgrow="ALWAYS">
            <TabPane fx:id="tabPane" VBox.vgrow="ALWAYS" styleClass="data-table">
                <Tab text="Layout &amp; Sections" closable="false">
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 16 0 0 0;">
                        <VBox spacing="15" styleClass="card">
                            <Label text="Receipt Sections" styleClass="card-title"/>
                            <Label text="Toggle visibility and reorder sections to customize your receipt layout. Drag or use arrows."
                                   style="-fx-text-fill: #64748b; -fx-wrap-text: true;"/>
                            <VBox fx:id="sectionsContainer" spacing="12"/>
                        </VBox>
                    </ScrollPane>
                </Tab>

                <Tab text="General Options" closable="false">
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 16 0 0 0;">
                        <VBox spacing="20" styleClass="card">
                            <Label text="Format Settings" styleClass="card-title"/>
                            <Label text="Configure paper size, date/time formats, and currency." style="-fx-text-fill: #64748b;"/>
                            
                            <GridPane hgap="20" vgap="20" style="-fx-padding: 10 0 0 0;">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50"/>
                                    <ColumnConstraints percentWidth="50"/>
                                </columnConstraints>

                                <VBox styleClass="form-group" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <Label text="Paper Width" styleClass="form-label"/>
                                    <ComboBox fx:id="paperWidthCombo" maxWidth="Infinity" styleClass="combo-box"/>
                                </VBox>

                                <VBox styleClass="form-group" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <Label text="Date Format" styleClass="form-label"/>
                                    <ComboBox fx:id="dateFormatCombo" maxWidth="Infinity" styleClass="combo-box"/>
                                </VBox>

                                <VBox styleClass="form-group" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <Label text="Time Format" styleClass="form-label"/>
                                    <ComboBox fx:id="timeFormatCombo" maxWidth="Infinity" styleClass="combo-box"/>
                                </VBox>

                                <VBox styleClass="form-group" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <Label text="Currency Symbol" styleClass="form-label"/>
                                    <TextField fx:id="currencyField" promptText="e.g. ₹, $, €" styleClass="text-field"/>
                                </VBox>
                            </GridPane>
                        </VBox>
                    </ScrollPane>
                </Tab>
            </TabPane>
        </VBox>

        <VBox spacing="10" style="-fx-min-width: 380; -fx-max-width: 380;">
            <VBox spacing="10" styleClass="card" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Live Preview" styleClass="card-title" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>
                <Label text="Thermal receipt preview" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                <Separator/>
                <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: #f1f5f9; -fx-border-color: #cbd5e1; -fx-border-radius: 4;">
                    <VBox style="-fx-alignment: top-center; -fx-padding: 20;">
                        <WebView fx:id="previewWebView" prefWidth="320" prefHeight="650" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);"/>
                    </VBox>
                </ScrollPane>
            </VBox>
        </VBox>
    </HBox>
</VBox>
