<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.possum.ui.common.controls.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.products.ProductsController"
      styleClass="workspace-view"
      stylesheets="@../../styles/inventory.css">

    <!-- Header -->
    <HBox styleClass="view-header" alignment="CENTER_LEFT">
        <VBox>
            <Label text="Products" styleClass="view-title"/>
            <Label text="Manage inventory items, pricing, and variants" styleClass="view-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="refreshButton" text="Refresh" onAction="#handleRefresh" styleClass="action-button" accessibleText="Refresh products table">
            <tooltip>
                <Tooltip text="Refresh the product list"/>
            </tooltip>
        </Button>
        <Button fx:id="addButton" text="+ Add Product" onAction="#handleAdd" styleClass="action-button, primary-button" accessibleText="Add a new product">
            <tooltip>
                <Tooltip text="Create a new product record"/>
            </tooltip>
        </Button>
    </HBox>

    <!-- Main Content -->
    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <FilterBar fx:id="filterBar"/>

        <DataTableView fx:id="productsTable" VBox.vgrow="ALWAYS" styleClass="data-table"/>

        <PaginationBar fx:id="paginationBar"/>
    </VBox>

</VBox>
