<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<fx:root type="javafx.scene.layout.StackPane" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml">
    <VBox styleClass="table-shadow-wrapper">
        <TableView fx:id="tableView" styleClass="data-table" VBox.vgrow="ALWAYS">
        </TableView>
    </VBox>
    
    <VBox fx:id="emptyState" styleClass="empty-state-view" alignment="CENTER" spacing="12" visible="false" managed="false">
        <FontIcon fx:id="emptyIcon" iconLiteral="bx-package" iconSize="48" styleClass="empty-state-icon" style="-fx-opacity: 0.4;"/>
        <Label fx:id="emptyMessage" text="No data available" styleClass="empty-state-title" style="-fx-font-size: 18px; -fx-font-weight: 700;"/>
        <Label fx:id="emptySubtitle" text="New records will appear here once available." styleClass="empty-state-subtitle" 
               style="-fx-font-size: 14px; -fx-wrap-text: true; -fx-text-alignment: center; -fx-max-width: 400;"/>
    </VBox>
    
    <StackPane fx:id="loadingOverlay" styleClass="table-loading-overlay" visible="false" managed="false">
        <ProgressIndicator maxWidth="50" maxHeight="50"/>
    </StackPane>
</fx:root>
