<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.returns.CreateReturnDialogController"
      spacing="15"
      prefWidth="600"
      style="-fx-background-color: white;">
    
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <!-- Header -->
    <VBox spacing="5" style="-fx-padding: 0 0 10 0;">
        <Label text="Process Return" styleClass="card-title" style="-fx-font-size: 20px;"/>
        <Label text="Select items to return from sale" styleClass="form-label"/>
    </VBox>

    <!-- Find Sale Section -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="saleInput" promptText="Enter Invoice # or Sale ID" accessibleText="Invoice or Sale ID Input" HBox.hgrow="ALWAYS" styleClass="text-field"/>
        <Button fx:id="findSaleButton" text="Find Sale" accessibleText="Find Sale Button" defaultButton="true" styleClass="action-button, primary-button">
            <tooltip>
                <Tooltip text="Find sale details by ID or Invoice number (Enter)"/>
            </tooltip>
        </Button>
    </HBox>

    <!-- Sale Details & Items Area (Initially hidden via logic) -->
    <VBox fx:id="saleDetailsArea" spacing="15" VBox.vgrow="ALWAYS">
        
        <!-- Info Bar -->
        <HBox spacing="20" style="-fx-background-color: #f1f5f9; -fx-padding: 10; -fx-background-radius: 6;">
            <VBox>
                <Label text="Invoice" style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>
                <Label fx:id="invoiceLabel" style="-fx-font-weight: bold;"/>
            </VBox>
            <VBox>
                <Label text="Sale ID" style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>
                <Label fx:id="saleIdLabel" style="-fx-font-weight: bold;"/>
            </VBox>
            <VBox>
                <Label text="Customer" style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>
                <Label fx:id="customerLabel" style="-fx-font-weight: bold;"/>
            </VBox>
        </HBox>

        <!-- Refund Summary Card -->
        <HBox fx:id="refundSummaryCard" spacing="15" alignment="CENTER_LEFT" 
              style="-fx-background-color: #f0f9ff; -fx-border-color: #bae6fd; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15;">
            <VBox HBox.hgrow="ALWAYS">
                <Label text="Estimated Refund Amount" style="-fx-text-fill: #0369a1; -fx-font-size: 12px;"/>
                <Label fx:id="totalRefundLabel" text="0.00" style="-fx-text-fill: #0369a1; -fx-font-size: 24px; -fx-font-weight: bold;"/>
            </VBox>
            <Label fx:id="itemsSelectedLabel" text="0 items selected" style="-fx-text-fill: #0369a1; -fx-font-weight: bold;"/>
        </HBox>

        <Label text="Select Items to Return" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 5 0 0 0;"/>
        
        <!-- Items List Wrapper -->
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS" minHeight="250">
            <VBox fx:id="itemsListContainer" spacing="12" style="-fx-padding: 5;"/>
        </ScrollPane>

        <!-- Reason Section -->
        <VBox spacing="8">
            <Label text="Reason for Return *" styleClass="form-label"/>
            <TextArea fx:id="reasonArea" promptText="e.g., Defective product, Wrong item..." accessibleText="Reason for Return Input" prefHeight="80" wrapText="true" styleClass="text-area"/>
        </VBox>

    </VBox>

    <Separator/>

    <!-- Footer Buttons -->
    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button fx:id="cancelButton" text="Cancel" accessibleText="Cancel Button" cancelButton="true" styleClass="action-button">
            <tooltip>
                <Tooltip text="Cancel and close dialog (Esc)"/>
            </tooltip>
        </Button>
        <Button fx:id="submitButton" text="Confirm Return" accessibleText="Confirm Return Button" onAction="#handleSubmit" styleClass="action-button, danger-button">
            <tooltip>
                <Tooltip text="Submit return processing"/>
            </tooltip>
        </Button>
    </HBox>

</VBox>
