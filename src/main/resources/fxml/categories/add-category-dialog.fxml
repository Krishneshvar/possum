<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.categories.AddCategoryDialogController"
      spacing="15"
      alignment="TOP_LEFT">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Add Category" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="15">
        <columnConstraints>
            <ColumnConstraints minWidth="100"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="nameField" promptText="Enter category name" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Parent Category:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <ComboBox fx:id="parentCategoryComboBox" promptText="Select Parent (Optional)" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    </GridPane>

    <Region VBox.vgrow="ALWAYS" />

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button text="Cancel" onAction="#handleCancel" styleClass="action-button"/>
        <Button text="Save" onAction="#handleSave" styleClass="action-button, primary-button"/>
    </HBox>

</VBox>
