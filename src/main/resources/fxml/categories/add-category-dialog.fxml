<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.categories.AddCategoryDialogController"
      style="-fx-background-color: #ffffff;"
      stylesheets="@../../styles/inventory.css">

    <padding>
        <Insets top="24" right="32" bottom="24" left="32"/>
    </padding>

    <VBox spacing="24" VBox.vgrow="ALWAYS">
        <!-- Header -->
        <VBox spacing="8">
            <Label fx:id="titleLabel" text="Add Category" styleClass="view-title" style="-fx-font-size: 20px;"/>
            <Label fx:id="subtitleLabel" text="Create a new product classification" styleClass="view-subtitle"/>
        </VBox>

        <!-- Form Fields -->
        <VBox spacing="20">
            <VBox styleClass="form-group">
                <Label text="Category Name *" styleClass="form-label" labelFor="$nameField"/>
                <TextField fx:id="nameField" promptText="Enter category name" styleClass="text-field" accessibleText="Input category name"/>
            </VBox>

            <VBox styleClass="form-group">
                <Label text="Parent Category" styleClass="form-label" labelFor="$parentCategoryComboBox"/>
                <ComboBox fx:id="parentCategoryComboBox" promptText="Select Parent (Optional)" maxWidth="Infinity" styleClass="combo-box" accessibleText="Select optional parent category"/>
            </VBox>
        </VBox>

        <Region VBox.vgrow="ALWAYS" />

        <!-- Actions -->
        <HBox alignment="CENTER_RIGHT" spacing="12">
            <Button text="Cancel" onAction="#handleCancel" styleClass="action-button" cancelButton="true" accessibleText="Cancel category creation">
                <tooltip>
                    <Tooltip text="Discard and close"/>
                </tooltip>
            </Button>
            <Button fx:id="saveButton" text="Save Category" onAction="#handleSave" styleClass="action-button, primary-button" defaultButton="true" accessibleText="Save new category">
                <tooltip>
                    <Tooltip text="Create the category"/>
                </tooltip>
            </Button>
        </HBox>
    </VBox>

</VBox>
