<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.possum.ui.categories.CategoriesController"
      spacing="20"
      alignment="TOP_LEFT">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="Categories" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Add Category" onAction="#handleAddCategory" styleClass="action-button, primary-button" />
    </HBox>

    <SplitPane dividerPositions="0.4" VBox.vgrow="ALWAYS">
        <!-- Tree View on the left -->
        <VBox spacing="10">
            <Label text="Category Hierarchy" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
            <TreeView fx:id="categoryTreeView" VBox.vgrow="ALWAYS" />
        </VBox>

        <!-- Table View on the right -->
        <VBox spacing="10">
            <Label text="All Categories" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
            <TableView fx:id="categoryTableView" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idCol" text="ID" prefWidth="50" />
                    <TableColumn fx:id="nameCol" text="Name" prefWidth="200" />
                    <TableColumn fx:id="parentCol" text="Parent Category" prefWidth="200" />
                </columns>
            </TableView>
        </VBox>
    </SplitPane>

</VBox>
